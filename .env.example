# Copy to backend/.env or export before starting.
# See docs/DEPLOYMENT.md for full matrix.

# -----------------------------------------------------------------------------
# Profile: local (default) | production | docker
# local → SQLite meta DB, sync execution, no Redis/MySQL required
# production → set DATABASE_URL / REDIS_URL / secrets below
# -----------------------------------------------------------------------------
APP_ENV=local

# --- Local defaults (leave blank to auto-use SQLite under backend/data/) ---
# DATABASE_URL=sqlite:///./data/meta.db
# EXECUTION_SYNC=true
# AUTO_MIGRATE=true
# SEED_DEMO_DATA=true

# --- Production / shared MySQL + Redis ---
# APP_ENV=production
# DATABASE_URL=mysql+pymysql://push:push@mysql-host:3306/push
# REDIS_URL=redis://redis-host:6379/0
# EXECUTION_SYNC=false
# SECRET_KEY=replace-me
# TOKEN_FERNET_KEY=  # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
# STORAGE_ROOT=/var/lib/data-push/storage
# CORS_ORIGINS=["https://push.example.com"]

# Optional: PNG screenshots for artboard (local works without it)
#   pip install playwright && python -m playwright install chromium
