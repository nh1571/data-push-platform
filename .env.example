DATABASE_URL=mysql+pymysql://push:push@localhost:3306/push
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
# Generate a valid Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_FERNET_KEY=change-me-fernet-key-32bytes-base64!!
STORAGE_ROOT=./storage
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Bootstrap admin (created on startup when operators table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# JWT access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# When true, job runs execute in-process (no Celery worker required)
EXECUTION_SYNC=true

